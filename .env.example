# Example environment variables for CARTHAGE trading system

# API keys
API_KEY="your_api_key"
API_SECRET="your_api_secret"

# Database configuration
DB_HOST="localhost"
DB_PORT=5432
DB_USER="your_db_user"
DB_PASSWORD="your_db_password"
DB_NAME="your_db_name"

# Trading parameters
TRADE_AMOUNT=1000
MAX_ORDERS=10
